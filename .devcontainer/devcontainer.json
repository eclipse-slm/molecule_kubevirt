{
	"image": "ghcr.io/eclipse-slm/molecule:26.3.0",
  	"initializeCommand": "docker pull ghcr.io/eclipse-slm/molecule:26.3.0",
	"containerUser": "root",
	"runArgs": [
		"--privileged",
		"--device",
		"/dev/fuse",
		"--hostname=ansible-dev-container"
	],
	"updateRemoteUserUID": true,
	"mounts": [
		"source=${localEnv:USERPROFILE}/.gitconfig,target=/root/.gitconfig,type=bind,consistency=cached",
		"source=${localEnv:USERPROFILE}/.kube/config,target=/root/.kube/config,type=bind,consistency=cached"
	],
	"customizations": {
		"vscode": {
			"extensions": [
				"redhat.ansible",
				"ms-python.python"
			]
		}
	}
}